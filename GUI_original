LRESULT CALLBACK MainWndProc(HWND hWnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
    case WM_CREATE: {
        CreateWindowA("STATIC", "Smart Trip Assistant",
            WS_CHILD|WS_VISIBLE|SS_CENTER,
            0, 30, 400, 30, hWnd, NULL, g_hInst, NULL);

        CreateWindowA("STATIC", "Plan your journey through Northern Thailand",
            WS_CHILD|WS_VISIBLE|SS_CENTER,
            0, 65, 400, 16, hWnd, NULL, g_hInst, NULL);

        CreateWindowA("BUTTON", "[ 1 ]  Plan Trip",
            WS_CHILD|WS_VISIBLE|BS_PUSHBUTTON,
            100, 110, 200, 40, hWnd, (HMENU)ID_BTN_PLAN_TRIP, g_hInst, NULL);

        CreateWindowA("BUTTON", "[ 2 ]  What to Eat Today?",
            WS_CHILD|WS_VISIBLE|BS_PUSHBUTTON,
            100, 165, 200, 40, hWnd, (HMENU)ID_BTN_WHAT_TO_EAT, g_hInst, NULL);

        CreateWindowA("BUTTON", "[ 3 ]  Exit",
            WS_CHILD|WS_VISIBLE|BS_PUSHBUTTON,
            100, 220, 200, 40, hWnd, (HMENU)ID_BTN_EXIT, g_hInst, NULL);
        return 0;
    }
    case WM_COMMAND:
        switch (LOWORD(wParam)) {
        case ID_BTN_PLAN_TRIP:    ShowPlanTripDialog(hWnd);  break;
        case ID_BTN_WHAT_TO_EAT: ShowWhatToEatDialog(hWnd); break;
        case ID_BTN_EXIT:        DestroyWindow(hWnd);        break;
        }
        return 0;
    case WM_DESTROY:
        PostQuitMessage(0);
        return 0;
    }
    return DefWindowProcA(hWnd, msg, wParam, lParam);
}

// ─────────────────────────────────────────
//  WinMain
// ─────────────────────────────────────────
int WINAPI WinMain(HINSTANCE hInstance, HINSTANCE, LPSTR, int nCmdShow) {
    g_hInst = hInstance;
    InitCommonControls();

    WNDCLASSEXA wc = {};
    wc.cbSize        = sizeof(wc);
    wc.style         = CS_HREDRAW | CS_VREDRAW;
    wc.lpfnWndProc   = MainWndProc;
    wc.hInstance     = hInstance;
    wc.hCursor       = LoadCursor(NULL, IDC_ARROW);
    wc.hbrBackground = (HBRUSH)(COLOR_BTNFACE + 1);
    wc.lpszClassName = "SmartTripMainWnd";
    wc.hIcon         = LoadIcon(NULL, IDI_APPLICATION);
    RegisterClassExA(&wc);

    int sw = GetSystemMetrics(SM_CXSCREEN);
    int sh = GetSystemMetrics(SM_CYSCREEN);
    int ww = 400, wh = 310;

    g_hMain = CreateWindowExA(0, "SmartTripMainWnd", "Smart Trip Assistant",
        WS_OVERLAPPED|WS_CAPTION|WS_SYSMENU|WS_MINIMIZEBOX,
        (sw-ww)/2, (sh-wh)/2, ww, wh,
        NULL, NULL, hInstance, NULL);

    ShowWindow(g_hMain, nCmdShow);
    UpdateWindow(g_hMain);

    MSG msg;
    while (GetMessage(&msg, NULL, 0, 0)) {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }
    return (int)msg.wParam;
}
