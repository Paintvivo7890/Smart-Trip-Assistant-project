static std::string GetDlgItemStr(HWND hDlg, int id) {
    char buf[256] = {};
    GetDlgItemTextA(hDlg, id, buf, 256);
    return std::string(buf);
}
static int GetDlgItemInt2(HWND hDlg, int id) {
    try { return std::stoi(GetDlgItemStr(hDlg, id)); }
    catch (...) { return 0; }
}
static void LB_Add(HWND hList, const std::string& s) {
    SendMessageA(hList, LB_ADDSTRING, 0, (LPARAM)s.c_str());
}
static void CB_Add(HWND hCombo, const std::string& s) {
    SendMessageA(hCombo, CB_ADDSTRING, 0, (LPARAM)s.c_str());
}

