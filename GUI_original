static std::vector<Place> SearchPlaces(int pvSel, int stSel) {
    // pvSel : 0-based index จาก ComboBox → แปลงเป็น 1-17
    // stSel : 0-based index (0=Culture ... 5=Random)

    vector<int> pvVec = { pvSel + 1 };          // ✅ vector<int> ตาม signature
    vector<int> stVec = { stSel + 1 };          // ✅ vector<int> ตาม signature

    vector<Place> filtered = Screening_province(allplace, pvVec);

    if (stSel == 5) {
        // Random → คืนทุกที่ในจังหวัดนั้น
        return filtered;
    }

    vector<Place> result = Recommendation_place(filtered, stVec);
    return result;
}

// ─────────────────────────────────────────
//  Dialog: Plan Trip
// ─────────────────────────────────────────
INT_PTR CALLBACK PlanTripDlgProc(HWND hDlg, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
    case WM_INITDIALOG: {
        HWND hPv = GetDlgItem(hDlg, ID_COMBO_PROVINCE);
        for (auto& p : PROVINCES) CB_Add(hPv, p);
        SendMessage(hPv, CB_SETCURSEL, 0, 0);

        HWND hSt = GetDlgItem(hDlg, ID_COMBO_STYLE);
        for (auto& s : STYLES) CB_Add(hSt, s);
        SendMessage(hSt, CB_SETCURSEL, 0, 0);

        return TRUE;
    }
    case WM_COMMAND: {
        int wID = LOWORD(wParam);

        if (wID == ID_BTN_SEARCH) {
            int people = GetDlgItemInt2(hDlg, ID_EDIT_PEOPLE);
            int budget = GetDlgItemInt2(hDlg, ID_EDIT_BUDGET);
            int days   = GetDlgItemInt2(hDlg, ID_EDIT_DAYS);

            int pvSel = (int)SendMessage(GetDlgItem(hDlg, ID_COMBO_PROVINCE), CB_GETCURSEL, 0, 0);
            int stSel = (int)SendMessage(GetDlgItem(hDlg, ID_COMBO_STYLE),    CB_GETCURSEL, 0, 0);
            HWND hList = GetDlgItem(hDlg, ID_LIST_RESULT);

            if (people <= 0 || days <= 0) {
                MessageBoxA(hDlg, "Please fill in valid People and Days (> 0).",
                    "Input Error", MB_OK | MB_ICONWARNING);
                return TRUE;
            }

            // ค้นหาสถานที่
            std::vector<Place> results = SearchPlaces(pvSel, stSel);

            SendMessage(hList, LB_RESETCONTENT, 0, 0);

            if (results.empty()) {
                LB_Add(hList, "No places found for this selection.");
            } else {
                // Header
                std::string header = "=== " + std::string(PROVINCES[pvSel])
                                   + " | " + STYLES[stSel]
                                   + " | " + std::to_string(people) + " person(s)"
                                   + " | " + std::to_string(days) + " day(s) ===";
                LB_Add(hList, header);
                LB_Add(hList, "");

                int no = 1, totalCost = 0;
                for (auto& p : results) {
                    LB_Add(hList, std::to_string(no++) + ".  " + p.name
                                  + "  [" + p.district + "]");
                    LB_Add(hList, "    Entrance : "
                                  + (p.price == 0 ? std::string("Free")
                                                  : std::to_string(p.price) + " THB/person"));
                    totalCost += p.price * people;
                }

                LB_Add(hList, "");
                LB_Add(hList, "-------------------------------");
                LB_Add(hList, "Total entrance cost : " + std::to_string(totalCost) + " THB");
                if (budget > 0) {
                    LB_Add(hList, "Remaining budget    : "
                                  + std::to_string(budget - totalCost) + " THB");
                }
            }
            return TRUE;
        }

        if (wID == ID_BTN_CLOSE_PLAN || wID == IDCANCEL) {
            EndDialog(hDlg, 0);
            return TRUE;
        }
        break;
    }
    case WM_CLOSE:
        EndDialog(hDlg, 0);
        return TRUE;
    }
    return FALSE;
}

// ─────────────────────────────────────────
//  Dialog: What to Eat
// ─────────────────────────────────────────
INT_PTR CALLBACK WhatToEatDlgProc(HWND hDlg, UINT msg, WPARAM wParam, LPARAM lParam) {
    static const char* NOODLES[] = {
        "Pad Thai","Boat Noodles","Tom Yum Noodles","Khao Soi","Bamee Moo Daeng"
    };
    static const char* RICE[] = {
        "Khao Pad","Khao Man Gai","Khao Moo Daeng","Khao Na Ped","Khao Kha Moo"
    };
    static const char* RANDOM[] = {
        "Som Tum","Larb","Massaman Curry","Green Curry","Mango Sticky Rice",
        "Pad Thai","Khao Man Gai","Tom Kha Gai","Pad Kra Pao","Satay"
    };

    switch (msg) {
    case WM_INITDIALOG: {
        HWND hCat = GetDlgItem(hDlg, ID_COMBO_CATEGORY);
        CB_Add(hCat, "Noodles");
        CB_Add(hCat, "Rice");
        CB_Add(hCat, "Surprise me!");
        SendMessage(hCat, CB_SETCURSEL, 0, 0);
        return TRUE;
    }
    case WM_COMMAND: {
        int wID = LOWORD(wParam);

        if (wID == ID_BTN_EAT_GO) {
            int customer = GetDlgItemInt2(hDlg, ID_EDIT_CUSTOMER);
            int catSel   = (int)SendMessage(GetDlgItem(hDlg, ID_COMBO_CATEGORY), CB_GETCURSEL, 0, 0);
            HWND hList   = GetDlgItem(hDlg, ID_LIST_EAT_RESULT);

            if (customer <= 0) {
                MessageBoxA(hDlg, "Please enter number of people (> 0).",
                    "Input Error", MB_OK | MB_ICONWARNING);
                return TRUE;
            }

            SendMessage(hList, LB_RESETCONTENT, 0, 0);
            LB_Add(hList, "=== Meal Recommendation for "
                          + std::to_string(customer) + " person(s) ===");
            LB_Add(hList, "");

            srand((unsigned)GetTickCount());
            for (int i = 1; i <= customer; i++) {
                LB_Add(hList, "Person [" + std::to_string(i) + "] :");
                std::string meal;
                if      (catSel == 0) meal = NOODLES[rand() % 5];
                else if (catSel == 1) meal = RICE   [rand() % 5];
                else                 meal = RANDOM  [rand() % 10];
                LB_Add(hList, "   --> " + meal);
                LB_Add(hList, "");
            }
            return TRUE;
        }

        if (wID == ID_BTN_CLOSE_EAT || wID == IDCANCEL) {
            EndDialog(hDlg, 0);
            return TRUE;
        }
        break;
    }
    case WM_CLOSE:
        EndDialog(hDlg, 0);
        return TRUE;
    }
    return FALSE;
}

// ─────────────────────────────────────────
//  DlgBuilder — สร้าง Dialog in-code (ไม่ต้องใช้ .rc)
// ─────────────────────────────────────────
#define DLGBUF_SIZE 4096
struct DlgBuilder {
    BYTE buf[DLGBUF_SIZE];
    int  pos = 0;

    void align4() { pos = (pos + 3) & ~3; }
    void addW (WORD  v) { *(WORD* )(buf+pos)=v; pos+=2; }
    void addDW(DWORD v) { *(DWORD*)(buf+pos)=v; pos+=4; }
    void addWStr(const wchar_t* s) { while(*s) addW((WORD)*s++); addW(0); }

    void addCtrl(DWORD style, short x, short y, short w, short h,
                 WORD id, const wchar_t* cls, const wchar_t* txt) {
        align4();
        addDW(style | WS_CHILD | WS_VISIBLE);
        addDW(0);
        addW((WORD)x); addW((WORD)y); addW((WORD)w); addW((WORD)h);
        addW(id);
        addWStr(cls);
        addWStr(txt);
        addW(0);
    }
};

